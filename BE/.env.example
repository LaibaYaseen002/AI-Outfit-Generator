# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Supabase
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=user-photos

# LLM provider — works with OpenAI or any OpenAI-compatible API (Groq, OpenRouter, Together, etc.)
# OpenAI default:
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL=gpt-4o-mini
#   (leave OPENAI_BASE_URL blank)
#
# Groq (free):
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_API_KEY=gsk_...
#   OPENAI_MODEL=llama-3.3-70b-versatile
#   OPENAI_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OPENAI_API_KEY=your-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
# Optional. Vision-capable model used for appearance detection (gender + age
# from the uploaded photo). Set only when OPENAI_MODEL is text-only — otherwise
# OPENAI_MODEL is reused. Required when using Groq's llama-3.3 text model.
OPENAI_VISION_MODEL=

# Image generation (outfit preview).
# Provider switch: 'huggingface' (free) or 'openai' (paid).
# Defaults to huggingface so the app works without an OpenAI billing account.
IMAGE_PROVIDER=huggingface
IMAGE_SIZE=1024x1024

# --- Hugging Face (free) ---
# Get a free Read token at https://huggingface.co/settings/tokens
HF_API_KEY=hf_your-token
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# --- OpenAI (paid, used only when IMAGE_PROVIDER=openai) ---
# By default reuses OPENAI_API_KEY against OpenAI's images API. Override these
# only if your text LLM provider above doesn't host image models (e.g. Groq,
# OpenRouter — set IMAGE_API_KEY to a real OpenAI key and leave IMAGE_BASE_URL empty).
IMAGE_API_KEY=
IMAGE_BASE_URL=
IMAGE_MODEL=gpt-image-1

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- AI Fashion Designer (Design Studio) ---
# Image generation via Pollinations.ai — completely free, no signup, no API key.
# The service is called server-side, so no key needs to be exposed anywhere.
# Pollinations conditions on a single reference image (the first reference
# uploaded for the design); the other references are described in the prompt
# via their cached analysis (colors, embroidery, cultural style, summary).
# Models: flux (default, reliable), flux-realism (photoreal), kontext (img-edit).
DESIGN_IMAGE_MODEL=kontext
